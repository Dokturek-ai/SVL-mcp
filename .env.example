# Veřejná URL widgetu. V lokálním dev s tunelem (ngrok / cloudflared) sem
# vložte HTTPS URL tunelu, aby se assety uvnitř iframe hostitele resolvovaly
# správně. Na Vercelu se odvozuje automaticky z VERCEL_* proměnných.
BASE_URL=

# LightRAG read-only API
# Plná základní URL nasazeného LightRAG serveru (bez koncového lomítka).
# Pro lokální vývoj např.: http://localhost:8000
LIGHTRAG_BASE_URL=https://dokturek-lightrag-production.up.railway.app
# Produkční API klíč LightRAG (posílá se v hlavičce X-API-Key).
LIGHTRAG_API_KEY=

# ---------------------------------------------------------------------------
# OAuth brána (přístup k MCP po ověření e-mailu)
# ---------------------------------------------------------------------------
# Tajemství pro podpis všech tokenů (HS256). Povinné. Vygenerujte např.:
#   openssl rand -base64 48
AUTH_SECRET=

# Resend (odesílání magic-link e-mailu)
RESEND_API_KEY=
# Odesílatel na ověřené doméně, např. "Doktůrek.ai <noreply@dokturek.ai>"
EMAIL_FROM=

# Notion (ukládání leadů)
# Token interní Notion integrace; databáze musí být s integrací nasdílená.
NOTION_TOKEN=
# ID Notion databáze (32 hex znaků z URL databáze).
NOTION_DATABASE_ID=
# Volitelné: názvy sloupců, pokud se liší od výchozích.
# NOTION_PROP_EMAIL=Email
# NOTION_PROP_POSITION=Pozice
# NOTION_PROP_FIRSTNAME=Jméno
# NOTION_PROP_LASTNAME=Příjmení
# NOTION_PROP_SOURCE=Zdroj
