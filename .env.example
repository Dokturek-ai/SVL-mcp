# Veřejná URL widgetu. V lokálním dev s tunelem (ngrok / cloudflared) sem
# vložte HTTPS URL tunelu, aby se assety uvnitř iframe hostitele resolvovaly
# správně. Na Vercelu se odvozuje automaticky z VERCEL_* proměnných.
BASE_URL=

# LightRAG read-only API
# Plná základní URL nasazeného LightRAG serveru (bez koncového lomítka).
# Pro lokální vývoj např.: http://localhost:8000
LIGHTRAG_BASE_URL=https://dokturek-lightrag-production.up.railway.app
# Produkční API klíč LightRAG (posílá se v hlavičce X-API-Key).
LIGHTRAG_API_KEY=
